@page "/"
@rendermode InteractiveServer
@using System.Text
@using System.Text.Json
@using BlazorJsonVisualizer.PreparedDocuments
@inject IPreparedJsonDocumentStore PreparedDocumentStore
@inject IJsonDocumentImporter JsonDocumentImporter
@inject IJsonDocumentExporter JsonDocumentExporter
@inject IPreparedDocumentRuntimeBridge PreparedRuntimeBridge

<PageTitle>Layer 1 Prepared Document Viewer Sample</PageTitle>

<h1>Layer 1 Prepared Document Viewer Sample</h1>

<p>
    This sample demonstrates the read-only prepared-document Layer 1 path: import or select a prepared document,
    open it through the range-backed viewer, scroll bounded row windows, fold rows, search the prepared source,
    page results, reveal results, and inspect diagnostics/index states.
</p>

<section style="margin-bottom: 1.5rem; border: 1px solid #cbd5e1; border-radius: 8px; padding: 1rem; display: grid; gap: 1rem;">
    <div>
        <h2 style="font-size: 1.1rem; margin-top: 0;">Prepared document selection</h2>
        <p style="margin-top: 0;">The sample store is backed by a temporary file store and starts with a seeded document.</p>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
            <select @bind="_selectedDocumentId"
                    style="min-width: 18rem; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;"
                    aria-label="Prepared document">
                @foreach (var document in _documents)
                {
                    <option value="@document.DocumentId">@document.DocumentId (@document.SourceLength bytes, @document.State)</option>
                }
            </select>
            <button @onclick="OpenSelectedDocumentAsync"
                    style="padding: 0.5rem 0.75rem; border: 1px solid #2563eb; background: #2563eb; color: white; border-radius: 4px; cursor: pointer;">
                Open selected
            </button>
        </div>
    </div>

    <div>
        <h2 style="font-size: 1.1rem; margin-top: 0;">Import sample JSON</h2>
        <textarea @bind="_importJson"
                  rows="8"
                  style="width: 100%; box-sizing: border-box; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace; border: 1px solid #cbd5e1; border-radius: 4px; padding: 0.5rem;"
                  aria-label="JSON to import"></textarea>
        <div style="margin-top: 0.5rem; display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
            <input @bind="_importDocumentId"
                   placeholder="optional-document-id"
                   style="flex: 1 1 16rem; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;"
                   aria-label="Optional import document id" />
            <button @onclick="ImportJsonAsync"
                    style="padding: 0.5rem 0.75rem; border: 1px solid #047857; background: #047857; color: white; border-radius: 4px; cursor: pointer;">
                Import and open
            </button>
        </div>
        @if (!string.IsNullOrWhiteSpace(_sampleMessage))
        {
            <p style="margin-bottom: 0;">@_sampleMessage</p>
        }
    </div>

    <div>
        <h2 style="font-size: 1.1rem; margin-top: 0;">Edited export and degraded state</h2>
        <p style="margin-top: 0;">Apply a controlled edit to the open session, export the edited revision, or import a document without search/path indexes to make degraded diagnostics visible.</p>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
            <button @onclick="ReplaceEnabledAndExportAsync">Replace enabled and export</button>
            <button @onclick="ExportPreparedDocumentAsync" disabled="@string.IsNullOrWhiteSpace(_preparedDocumentId)">Export open document</button>
            <button @onclick="ImportMissingIndexDocumentAsync">Import missing-index sample</button>
        </div>
        <pre style="margin-bottom: 0; white-space: pre-wrap;">@_exportMessage</pre>
    </div>

</section>

@if (string.IsNullOrWhiteSpace(_preparedDocumentId))
{
    <p>Preparing sample document…</p>
}
else
{
    <JsonVisualizer @key="_preparedDocumentId"
                    @ref="_visualizer"
                    SessionId="layer1-session"
                    PreparedDocumentId="@_preparedDocumentId"
                    RuntimeEvent="HandleRuntimeEvent" />
}

<section style="margin-top: 1.5rem; display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));">
    <section style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 1rem;">
        <h2 style="font-size: 1.1rem; margin-top: 0;">Reveal JSON Pointer</h2>
        <p style="margin-top: 0;">Enter a prepared-document JSON Pointer such as <code>/document/nested/items</code>.</p>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
            <input @bind="_revealPath"
                   style="flex: 1 1 16rem; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;"
                   aria-label="Reveal JSON Pointer" />
            <button @onclick="RevealPreparedPathAsync"
                    style="padding: 0.5rem 0.75rem; border: 1px solid #2563eb; background: #2563eb; color: white; border-radius: 4px; cursor: pointer;">
                Reveal JSON Pointer
            </button>
        </div>
        <div style="margin-top: 0.75rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <button @onclick='() => SetRevealPath("/document/nested")'>Reveal nested</button>
            <button @onclick='() => SetRevealPath("/features")'>Reveal features</button>
            <button @onclick='() => SetRevealPath("/")'>Reveal root</button>
        </div>
    </section>

    <section style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 1rem;">
        <h2 style="font-size: 1.1rem; margin-top: 0;">Latest runtime event</h2>
        <p><strong>Type:</strong> @_latestEvent.Type</p>
        <p><strong>Session:</strong> @_latestEvent.SessionId</p>
        <p><strong>Document:</strong> @_latestEvent.DocumentId</p>
        <p><strong>Message:</strong> @_latestEvent.Message</p>
    </section>

    <section style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 1rem;">
        <h2 style="font-size: 1.1rem; margin-top: 0;">Prepared diagnostics</h2>
        @if (_diagnostics.Count == 0)
        {
            <p>No diagnostics.</p>
        }
        else
        {
            <ul>
                @foreach (var diagnostic in _diagnostics)
                {
                    <li><strong>@diagnostic.Severity</strong>: @diagnostic.Message (@diagnostic.Code, @diagnostic.StartOffset-@diagnostic.EndOffset)</li>
                }
            </ul>
        }
    </section>

    <section style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 1rem;">
        <h2 style="font-size: 1.1rem; margin-top: 0;">Prepared search</h2>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
            <input @bind="_searchQuery"
                   style="flex: 1 1 16rem; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;"
                   aria-label="Search prepared document" />
            <label style="display: inline-flex; gap: 0.25rem; align-items: center;">
                <input type="checkbox" @bind="_ignoreCase" /> Ignore case
            </label>
            <button @onclick="SearchPreparedDocumentAsync"
                    style="padding: 0.5rem 0.75rem; border: 1px solid #2563eb; background: #2563eb; color: white; border-radius: 4px; cursor: pointer;">
                Search
            </button>
            <button @onclick="ContinueSearchAsync" disabled="@string.IsNullOrWhiteSpace(_continuationToken)">
                Next page
            </button>
        </div>
        @if (_searchDiagnostics.Count > 0)
        {
            <ul style="margin-top: 0.75rem; color: #7f1d1d;">
                @foreach (var diagnostic in _searchDiagnostics)
                {
                    <li>@diagnostic.Message (@diagnostic.Code)</li>
                }
            </ul>
        }
        @if (_searchResults.Count == 0)
        {
            <p style="margin-top: 0.75rem;">No results yet.</p>
        }
        else
        {
            <p style="margin-bottom: 0;">Revision @_searchRevision. Continuation: @(string.IsNullOrWhiteSpace(_continuationToken) ? "end" : _continuationToken)</p>
            <ul style="margin-top: 0.75rem;">
                @foreach (var result in _searchResults)
                {
                    <li>
                        <button @onclick="() => RevealPreparedSearchResultAsync(result)">Reveal</button>
                        <code>@(result.Path ?? result.ResultId)</code>
                        <span style="margin-left: 0.5rem;">@result.Preview</span>
                        <small style="margin-left: 0.5rem;">rev @result.Revision, bytes @result.StartByteOffset-@result.EndByteOffset</small>
                    </li>
                }
            </ul>
        }
    </section>
</section>

@code {
    private const string SamplePreparedDocumentId = "layer1-prepared-sample";
    private JsonVisualizer? _visualizer;
    private string? _preparedDocumentId;
    private string? _selectedDocumentId;
    private string? _continuationToken;
    private string _revealPath = "/document/nested";
    private string _searchQuery = "viewing";
    private string _importDocumentId = string.Empty;
    private string _sampleMessage = string.Empty;
    private string _exportMessage = "No export attempted yet.";
    private bool _ignoreCase = true;
    private long _searchRevision;
    private RuntimeEventDto _latestEvent = new(RuntimeEventTypes.SessionCreated, "layer1-session", "Waiting for runtime event.");
    private List<PreparedJsonDocumentInfo> _documents = [];
    private List<RuntimeDiagnosticDto> _diagnostics = [];
    private List<RuntimeDiagnosticDto> _searchDiagnostics = [];
    private List<PreparedSearchResultDto> _searchResults = [];

    private string _importJson = SampleJson;

    private const string SampleJson = """
{
  "project": "BlazorJsonVisualizer",
  "layer": 1,
  "features": ["viewing", "folding", "navigation", "search", "viewing again"],
  "document": {
    "kind": "sample",
    "nested": {
      "enabled": true,
      "items": [1, 2, 3]
    }
  }
}
""";

    protected override async Task OnInitializedAsync()
    {
        await EnsureSeedDocumentAsync();
        await RefreshDocumentListAsync();
        _selectedDocumentId = _documents.FirstOrDefault()?.DocumentId;
        _preparedDocumentId = _selectedDocumentId;
    }

    private async Task EnsureSeedDocumentAsync()
    {
        var existing = await PreparedDocumentStore.GetAsync(SamplePreparedDocumentId);
        if (existing is not null)
        {
            return;
        }

        await ImportJsonCoreAsync(SampleJson, SamplePreparedDocumentId);
    }

    private async Task RefreshDocumentListAsync()
    {
        _documents = (await PreparedDocumentStore.ListAsync()).ToList();
    }

    private Task OpenSelectedDocumentAsync()
    {
        if (!string.IsNullOrWhiteSpace(_selectedDocumentId))
        {
            _preparedDocumentId = _selectedDocumentId;
            _searchResults = [];
            _searchDiagnostics = [];
            _continuationToken = null;
        }

        return Task.CompletedTask;
    }

    private async Task ImportJsonAsync()
    {
        try
        {
            var documentId = string.IsNullOrWhiteSpace(_importDocumentId)
                ? $"layer1-import-{DateTimeOffset.UtcNow:yyyyMMddHHmmssfff}"
                : _importDocumentId.Trim();
            var imported = await ImportJsonCoreAsync(_importJson, documentId);
            await RefreshDocumentListAsync();
            _selectedDocumentId = imported.DocumentId;
            _preparedDocumentId = imported.DocumentId;
            _sampleMessage = $"Imported and opened prepared document '{imported.DocumentId}'.";
            _searchResults = [];
            _searchDiagnostics = [];
            _continuationToken = null;
        }
        catch (Exception exception) when (exception is JsonException or InvalidDataException or IOException)
        {
            _sampleMessage = $"Import failed: {exception.Message}";
        }
    }

    private async Task<PreparedJsonDocumentInfo> ImportJsonCoreAsync(string json, string documentId)
        => await ImportJsonCoreAsync(json, documentId, buildSearchIndex: true, buildPathIndex: true);

    private async Task<PreparedJsonDocumentInfo> ImportJsonCoreAsync(string json, string documentId, bool buildSearchIndex, bool buildPathIndex)
    {
        await using var sourceStream = new MemoryStream(Encoding.UTF8.GetBytes(json));
        return await JsonDocumentImporter.ImportAsync(sourceStream, new JsonDocumentImportOptions
        {
            DocumentId = documentId,
            BuildPathIndex = buildPathIndex,
            BuildSearchIndex = buildSearchIndex
        });
    }

    private async Task ImportMissingIndexDocumentAsync()
    {
        var documentId = $"layer1-missing-index-{DateTimeOffset.UtcNow:yyyyMMddHHmmssfff}";
        var imported = await ImportJsonCoreAsync(SampleJson, documentId, buildSearchIndex: false, buildPathIndex: false);
        await RefreshDocumentListAsync();
        _selectedDocumentId = imported.DocumentId;
        _preparedDocumentId = imported.DocumentId;
        _searchResults = [];
        _searchDiagnostics = [];
        _continuationToken = null;
        _exportMessage = "Opened missing-index sample. Search and JSON Pointer reveal should report explicit missing-index diagnostics.";
    }

    private async Task ReplaceEnabledAndExportAsync()
    {
        if (string.IsNullOrWhiteSpace(_preparedDocumentId))
        {
            return;
        }

        var metadata = await PreparedRuntimeBridge.GetMetadataAsync("layer1-session");
        var rows = await PreparedRuntimeBridge.GetRowsAsync(new PreparedRowsRequestDto("layer1-session", 0, 100));
        var enabledRow = rows.Rows.FirstOrDefault(static row => row.Text.Contains("\"enabled\": true", StringComparison.Ordinal));
        if (enabledRow?.NodeId is null)
        {
            _exportMessage = "Could not find an enabled primitive row to edit. Reopen the seeded ready document and try again.";
            return;
        }

        using var value = JsonDocument.Parse("false");
        var edit = _visualizer is null
            ? await PreparedRuntimeBridge.ApplyEditAsync(new PreparedEditCommandDto(
                "layer1-session",
                _preparedDocumentId,
                metadata.Revision,
                PreparedEditCommandKinds.ReplaceNodeValue,
                TargetNodeId: enabledRow.NodeId,
                Value: value.RootElement,
                Label: "Sample replace enabled"))
            : await _visualizer.ReplacePreparedPrimitiveValueAsync(enabledRow.NodeId, metadata.Revision, value.RootElement, "Sample replace enabled");

        if (!edit.Success)
        {
            _exportMessage = "Edit failed: " + string.Join("; ", edit.Diagnostics?.Select(static diagnostic => $"{diagnostic.Code}: {diagnostic.Message}") ?? []);
            return;
        }

        await ExportPreparedDocumentAsync();
    }

    private async Task ExportPreparedDocumentAsync()
    {
        if (string.IsNullOrWhiteSpace(_preparedDocumentId))
        {
            return;
        }

        await using var destination = new MemoryStream();
        try
        {
            var result = await JsonDocumentExporter.ExportWithResultAsync(_preparedDocumentId, destination, new JsonDocumentExportOptions());
            var json = Encoding.UTF8.GetString(destination.ToArray());
            _exportMessage = $"Exported revision {result.ExportedRevision} with {result.TransactionCount} transaction(s): {json}";
        }
        catch (JsonDocumentExportException exception)
        {
            _exportMessage = $"Export diagnostic {exception.Diagnostic.Code}: {exception.Diagnostic.Message}";
        }
        catch (Exception exception) when (exception is InvalidDataException or InvalidOperationException or IOException)
        {
            _exportMessage = $"Export failed: {exception.Message}";
        }
    }

    private async Task RevealPreparedPathAsync()
    {
        if (_visualizer is null)
        {
            return;
        }

        await _visualizer.RevealPreparedJsonPointerAsync(_revealPath);
    }

    private async Task SearchPreparedDocumentAsync()
    {
        await SearchPreparedDocumentPageAsync(null);
    }

    private async Task ContinueSearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_continuationToken))
        {
            return;
        }

        await SearchPreparedDocumentPageAsync(_continuationToken);
    }

    private async Task SearchPreparedDocumentPageAsync(string? continuationToken)
    {
        if (_visualizer is null)
        {
            return;
        }

        var page = await _visualizer.SearchPreparedDocumentAsync(_searchQuery, maxResults: 3, ignoreCase: _ignoreCase, continuationToken: continuationToken);
        _searchResults = page.Results.ToList();
        _continuationToken = page.ContinuationToken;
        _searchDiagnostics = page.Diagnostics?.ToList() ?? [];
        _searchRevision = page.Revision;
    }

    private async Task RevealPreparedSearchResultAsync(PreparedSearchResultDto result)
    {
        if (_visualizer is null)
        {
            return;
        }

        await _visualizer.RevealPreparedSearchResultAsync(result);
    }

    private void SetRevealPath(string path)
    {
        _revealPath = path;
    }

    private async Task HandleRuntimeEvent(RuntimeEventDto runtimeEvent)
    {
        _latestEvent = runtimeEvent;

        if (runtimeEvent.Diagnostics is not null)
        {
            _diagnostics = runtimeEvent.Diagnostics.ToList();
        }

        await InvokeAsync(StateHasChanged);
    }
}
