@page "/"
@rendermode InteractiveServer
@using System.Text.Json
@using System.Reflection

<PageTitle>Visual Identity Playground</PageTitle>

<h1>Visual Identity Playground</h1>

<p>
    Demonstrates theme JSON import, token editing, validation, preview, and export.
    Representative Layer 1, Layer 2, and Layer 3 visual states are shown using the active theme tokens.
</p>

<div class="playground-grid">

    @* ── Theme Source Panel ── *@
    <section class="panel panel-theme-source">
        <h2>Theme Source</h2>
        <p class="panel-description">Paste or edit theme JSON. Changes update the preview.</p>
        <textarea value="@_themeJson"
                  @oninput="OnThemeJsonInput"
                  rows="12"
                  spellcheck="false"
                  aria-label="Theme JSON source"
                  class="code-input @(HasErrors ? "input-error" : "")"></textarea>
        <div class="button-row">
            <button @onclick="LoadDefaultTheme" class="btn-secondary">Load Default</button>
            <button @onclick="ResetTheme" class="btn-secondary">Reset</button>
        </div>
    </section>

    @* ── Validation Panel ── *@
    <section class="panel panel-validation">
        <h2>Validation</h2>
        @if (_validationErrors.Count == 0 && _isValid)
        {
            <p class="validation-ok">✓ Theme JSON is valid.</p>
        }
        else if (_validationErrors.Count > 0)
        {
            <ul class="validation-errors" role="list">
                @foreach (var error in _validationErrors)
                {
                    <li><strong>@error.Field:</strong> @error.Message</li>
                }
            </ul>
        }
        else
        {
            <p class="validation-pending">Enter or load theme JSON above.</p>
        }
    </section>

    @* ── Token Editor Panel ── *@
    <section class="panel panel-token-editor">
        <h2>Token Editor</h2>
        <p class="panel-description">Edit representative token values. Changes update the preview immediately.</p>
        @if (_isValid && _editableTokens.Count > 0)
        {
            <div class="token-groups">
                @foreach (var group in GetTokenGroups())
                {
                    <fieldset class="token-group">
                        <legend>@group.Key</legend>
                        @foreach (var token in group.Value)
                        {
                            <div class="token-row">
                                <label class="token-label" title="@token.Key">@ShortTokenName(token.Key)</label>
                                @if (IsColorToken(token.Key))
                                {
                                    <input type="color"
                                           value="@NormalizeColorForInput(token.Value)"
                                           @oninput="e => UpdateToken(token.Key, e.Value?.ToString() ?? token.Value)"
                                           class="token-color-input"
                                           aria-label="@token.Key" />
                                }
                                <input type="text"
                                       value="@token.Value"
                                       @oninput="e => UpdateToken(token.Key, e.Value?.ToString() ?? token.Value)"
                                       class="token-text-input"
                                       aria-label="@token.Key value" />
                            </div>
                        }
                    </fieldset>
                }
            </div>
        }
        else if (!_isValid)
        {
            <p class="panel-note">Fix validation errors to enable token editing.</p>
        }
    </section>

    @* ── Export Panel ── *@
    <section class="panel panel-export">
        <h2>Export</h2>
        <p class="panel-description">Copy normalized theme JSON for use in host applications.</p>
        @if (_isValid)
        {
            <textarea readonly
                      rows="10"
                      spellcheck="false"
                      class="code-input"
                      aria-label="Exported theme JSON">@GetExportedJson()</textarea>
            <div class="button-row">
                <button @onclick="CopyExportedJson" class="btn-primary">Copy JSON</button>
                @if (_copyConfirmed)
                {
                    <span class="copy-confirmed" role="status">Copied!</span>
                }
            </div>
        }
        else
        {
            <p class="panel-note">Valid theme JSON required for export.</p>
        }
    </section>

</div>

@* ── Preview Sections ── *@

<div class="preview-sections">

    @* Theme CSS variables applied to preview root *@
    <div class="bjv-root" data-bjv-theme="technical-calm-dark" style="@GetPreviewCssVars()">

        @* ── Layer 1 Preview ── *@
        <section class="preview-layer preview-layer1">
            <h2>Layer 1 — JSON Viewing Preview</h2>
