        @* ── Plugin-Local Token Preview ── *@
        <section class="preview-layer preview-plugin-tokens">
            <h2>Plugin-Local Token Preview</h2>
            <p class="preview-note">Shows plugin-local tokens from the current theme.</p>

            @if (_isValid && _pluginTokens.Count > 0)
            {
                @foreach (var plugin in _pluginTokens)
                {
                    <div class="plugin-token-group">
                        <h3>Plugin: <code>@plugin.Key</code></h3>
                        <ul class="plugin-token-list">
                            @foreach (var token in plugin.Value)
                            {
                                <li>
                                    <code class="plugin-token-name">@token.Key</code>:
                                    <span class="plugin-token-value">@token.Value</span>
