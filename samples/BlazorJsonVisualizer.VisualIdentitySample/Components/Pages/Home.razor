@code {
    private string _themeJson = string.Empty;
    private bool _isValid;
    private bool _copyConfirmed;
    private List<ValidationError> _validationErrors = [];
    private Dictionary<string, string> _editableTokens = [];
    private Dictionary<string, Dictionary<string, string>> _pluginTokens = [];

    private record ValidationError(string Field, string Message);

    protected override void OnInitialized()
    {
        LoadDefaultTheme();
    }

    private bool HasErrors => _validationErrors.Count > 0;

    private void LoadDefaultTheme()
    {
        var assembly = Assembly.GetExecutingAssembly();
        var resourceName = "BlazorJsonVisualizer.VisualIdentitySample.wwwroot.themes.technical-calm-dark.json";
        using var stream = assembly.GetManifestResourceStream(resourceName);
        if (stream is not null)
        {
            using var reader = new System.IO.StreamReader(stream);
            _themeJson = reader.ReadToEnd();
        }
        else
        {
            _themeJson = GetFallbackDefaultTheme();
        }

        ParseAndValidate();
    }

    private void ResetTheme()
    {
        LoadDefaultTheme();
    }

    private void OnThemeJsonInput(ChangeEventArgs e)
    {
        _themeJson = e.Value?.ToString() ?? string.Empty;
        ParseAndValidate();
    }

    private void ParseAndValidate()
    {
        _validationErrors = [];
        _isValid = false;
        _editableTokens = [];
        _pluginTokens = [];

        if (string.IsNullOrWhiteSpace(_themeJson))
        {
            return;
        }

        try
        {
            using var doc = JsonDocument.Parse(_themeJson);
            var root = doc.RootElement;

            if (root.ValueKind != JsonValueKind.Object)
            {
                _validationErrors.Add(new ValidationError("(root)", "Theme JSON must be a JSON object."));
                return;
            }

            if (!root.TryGetProperty("schemaVersion", out var sv) || sv.ValueKind != JsonValueKind.String)
                _validationErrors.Add(new ValidationError("schemaVersion", "Required field 'schemaVersion' must be a string."));
            else if (sv.GetString() != "1.0")
                _validationErrors.Add(new ValidationError("schemaVersion", $"Unsupported schemaVersion '{sv.GetString()}'. Supported: 1.0."));

            if (!root.TryGetProperty("id", out var id) || id.ValueKind != JsonValueKind.String)
                _validationErrors.Add(new ValidationError("id", "Required field 'id' must be a string."));

            if (!root.TryGetProperty("name", out var name) || name.ValueKind != JsonValueKind.String)
                _validationErrors.Add(new ValidationError("name", "Required field 'name' must be a string."));

            if (!root.TryGetProperty("mode", out var mode) || mode.ValueKind != JsonValueKind.String)
                _validationErrors.Add(new ValidationError("mode", "Required field 'mode' must be a string."));
            else if (mode.GetString() != "dark")
                _validationErrors.Add(new ValidationError("mode", $"Unsupported mode '{mode.GetString()}'. Supported: dark."));

            if (!root.TryGetProperty("tokens", out var tokens))
            {
                _validationErrors.Add(new ValidationError("tokens", "Required field 'tokens' is missing."));
            }
            else if (tokens.ValueKind != JsonValueKind.Object)
            {
                _validationErrors.Add(new ValidationError("tokens", "Field 'tokens' must be an object."));
            }
            else
            {
                foreach (var prop in tokens.EnumerateObject())
                {
                    if (prop.Value.ValueKind != JsonValueKind.String)
                    {
                        _validationErrors.Add(new ValidationError("tokens", $"Token '{prop.Name}' must have a string value."));
                    }
                    else
                    {
                        _editableTokens[prop.Name] = prop.Value.GetString() ?? string.Empty;
                    }
                }
            }

            if (root.TryGetProperty("plugins", out var plugins))
            {
                if (plugins.ValueKind != JsonValueKind.Object)
                {
                    _validationErrors.Add(new ValidationError("plugins", "Field 'plugins' must be an object."));
                }
                else
                {
                    foreach (var pluginProp in plugins.EnumerateObject())
                    {
                        if (pluginProp.Value.ValueKind != JsonValueKind.Object)
                        {
                            _validationErrors.Add(new ValidationError("plugins", $"Plugin '{pluginProp.Name}' must be an object."));
                            continue;
                        }

                        if (!pluginProp.Value.TryGetProperty("tokens", out var pluginTokens) ||
                            pluginTokens.ValueKind != JsonValueKind.Object)
                        {
                            _validationErrors.Add(new ValidationError("plugins", $"Plugin '{pluginProp.Name}' must have a 'tokens' object."));
                            continue;
                        }

                        var pluginTokenMap = new Dictionary<string, string>();
                        foreach (var pt in pluginTokens.EnumerateObject())
                        {
                            if (pt.Value.ValueKind != JsonValueKind.String)
                            {
                                _validationErrors.Add(new ValidationError("plugins", $"Plugin '{pluginProp.Name}' token '{pt.Name}' must be a string."));
                            }
                            else
                            {
                                pluginTokenMap[pt.Name] = pt.Value.GetString() ?? string.Empty;
                            }
                        }
                        _pluginTokens[pluginProp.Name] = pluginTokenMap;
                    }
                }
            }

            _isValid = _validationErrors.Count == 0;
        }
        catch (JsonException ex)
        {
            _validationErrors.Add(new ValidationError("(root)", $"Theme JSON is not valid JSON: {ex.Message}"));
        }
    }

    private void UpdateToken(string key, string value)
    {
        _editableTokens[key] = value;
        RebuildThemeJson();
    }

    private void RebuildThemeJson()
    {
        if (!_isValid && _editableTokens.Count == 0)
        {
            return;
        }

        try
        {
            using var doc = JsonDocument.Parse(_themeJson);
            var root = doc.RootElement;

            var updated = new Dictionary<string, object?>
            {
                ["schemaVersion"] = root.TryGetProperty("schemaVersion", out var sv) ? sv.GetString() : "1.0",
                ["id"] = root.TryGetProperty("id", out var id) ? id.GetString() : "custom",
                ["name"] = root.TryGetProperty("name", out var nm) ? nm.GetString() : "Custom Theme",
                ["mode"] = root.TryGetProperty("mode", out var md) ? md.GetString() : "dark",
                ["tokens"] = _editableTokens,
            };

            if (_pluginTokens.Count > 0)
            {
                updated["plugins"] = _pluginTokens.ToDictionary(
                    p => p.Key,
                    p => (object)new Dictionary<string, object> { ["tokens"] = p.Value }
                );
            }
            else
            {
                updated["plugins"] = new Dictionary<string, object>();
            }

            _themeJson = JsonSerializer.Serialize(updated, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            // If rebuild fails, leave the JSON as-is
        }
    }

    private string GetExportedJson()
    {
        if (!_isValid)
        {
            return string.Empty;
        }

        try
        {
            using var doc = JsonDocument.Parse(_themeJson);
            return JsonSerializer.Serialize(doc.RootElement, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return _themeJson;
        }
    }

    private async Task CopyExportedJson()
    {
        // In a real implementation this would use JS interop to copy to clipboard.
        // For this milestone placeholder, we toggle a "Copied" confirmation.
        _copyConfirmed = true;
        await Task.Delay(2000);
        _copyConfirmed = false;
        StateHasChanged();
    }

    private string GetPreviewCssVars()
    {
        if (!_isValid || _editableTokens.Count == 0)
        {
            return string.Empty;
        }

        var sb = new System.Text.StringBuilder();
        foreach (var token in _editableTokens)
        {
            var cssVar = "--bjv-" + token.Key.Replace(".", "-");
            sb.Append(cssVar);
            sb.Append(": ");
            sb.Append(token.Value);
            sb.Append("; ");
        }

        return sb.ToString();
    }

    private IEnumerable<KeyValuePair<string, List<KeyValuePair<string, string>>>> GetTokenGroups()
    {
        var groups = new Dictionary<string, List<KeyValuePair<string, string>>>();

        foreach (var token in _editableTokens)
        {
            var prefix = token.Key.Contains('.') ? token.Key.Split('.')[0] : "other";
            if (!groups.TryGetValue(prefix, out var list))
            {
                list = [];
                groups[prefix] = list;
            }

            list.Add(new KeyValuePair<string, string>(token.Key, token.Value));
        }

        foreach (var group in groups.OrderBy(g => g.Key))
        {
            yield return group;
        }
    }

    private static string ShortTokenName(string key)
    {
        var parts = key.Split('.');
        return parts.Length > 2 ? string.Join(".", parts.Skip(1)) : key;
    }

    private static bool IsColorToken(string key) =>
        key.StartsWith("color.", StringComparison.Ordinal) ||
        key.StartsWith("syntax.", StringComparison.Ordinal) ||
        key.StartsWith("state.", StringComparison.Ordinal) ||
        key.StartsWith("layer", StringComparison.Ordinal) ||
        key.StartsWith("focus.", StringComparison.Ordinal) ||
        key.StartsWith("selection.", StringComparison.Ordinal);

    private static string NormalizeColorForInput(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "#000000";
        }

        var trimmed = value.Trim();

        // Only 6-digit hex colors are reliably supported by <input type="color">
        if (trimmed.StartsWith('#') && trimmed.Length == 7)
        {
            return trimmed;
        }

        return "#000000";
    }

    private static string GetFallbackDefaultTheme() => """
{
  "schemaVersion": "1.0",
  "id": "technical-calm-dark",
  "name": "Technical Calm Dark",
  "mode": "dark",
  "tokens": {
    "color.canvas.background": "#0f1117",
    "color.surface.background": "#151923",
    "color.surface.elevated.background": "#1a2233",
    "color.border.default": "#252b38",
    "color.border.subtle": "#1c2230",
    "color.text.primary": "#e6e8ee",
    "color.text.secondary": "#b4bdcc",
    "color.text.muted": "#8892a6",
    "color.focus.ring": "#7aa2f7",
    "color.selection.background": "#1d2a3d",
    "color.selection.foreground": "#e6e8ee",
    "syntax.property.foreground": "#8fb4ff",
    "syntax.string.foreground": "#b6d987",
    "syntax.number.foreground": "#e6b450",
    "syntax.boolean.foreground": "#c792ea",
    "syntax.null.foreground": "#7f8795",
    "syntax.punctuation.foreground": "#9aa3b2",
    "syntax.invalid.foreground": "#f87171",
    "state.error.foreground": "#f87171",
    "state.error.background": "#3b1a1a",
    "state.warning.foreground": "#fbbf24",
    "state.warning.background": "#3b2e0a",
    "state.info.foreground": "#60a5fa",
    "state.info.background": "#1a2a3b",
    "state.suggestion.foreground": "#34d399",
    "layer1.activePath.background": "#1d2a3d",
    "layer1.row.hover.background": "#171d2a",
