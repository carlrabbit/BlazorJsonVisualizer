{
  "name": "BlazorJsonVisualizer Samples",
  "image": "mcr.microsoft.com/devcontainers/dotnet:2.1.1-10.0",
  "forwardPorts": [5100, 5110, 5120, 5130, 5140, 5150],
  "portsAttributes": {
    "5100": { "label": "Samples Index", "visibility": "public" },
    "5110": { "label": "Basic Sample", "visibility": "public" },
    "5120": { "label": "Layer 1 Sample", "visibility": "public" },
    "5130": { "label": "Layer 2 Schema Overlay Sample", "visibility": "public" },
    "5140": { "label": "Layer 3 Projection Sample", "visibility": "public" },
    "5150": { "label": "Visual Identity Playground", "visibility": "public" }
  },
  "postCreateCommand": "./eng/restore.sh",
  "postStartCommand": "bash eng/start-samples.sh --detach --log-file /tmp/blazor-json-visualizer-samples.log",
  "customizations": {
    "vscode": {
      "settings": {
        "dotnet.defaultSolution": ""
      }
    }
  }
}
