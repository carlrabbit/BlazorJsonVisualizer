{
  "name": "@blazor-json-visualizer/runtime",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "runtime-core",
    "runtime-dom",
    "runtime-worker",
    "runtime-blazor"
  ],
  "scripts": {
    "build": "npm run build:runtime-core && npm run build:runtime-dom && npm run build:runtime-worker && npm run build:runtime-blazor",
    "build:runtime-core": "npm --workspace runtime-core run build",
    "build:runtime-dom": "npm --workspace runtime-dom run build",
    "build:runtime-worker": "npm --workspace runtime-worker run build",
    "build:runtime-blazor": "npm --workspace runtime-blazor run build",
    "test": "npm run test:runtime-core && npm run test:layer1",
    "test:runtime-core": "npm --workspace runtime-core run test",
    "test:layer1": "cd ../../tests/runtime && npm install && npm test"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
