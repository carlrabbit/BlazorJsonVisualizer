@page "/"
@rendermode InteractiveServer
@using System.Text.Json

<PageTitle>BlazorJsonVisualizer Sample</PageTitle>

<h1>Layer 2 schema overlay prototype</h1>

<p>This sample loads a small JSON document, attaches a schema overlay, surfaces parse and schema diagnostics, and demonstrates schema-aware runtime hints.</p>

<JsonVisualizer @ref="_visualizer"
                SessionId="sample-session"
                DocumentId="sample-document"
                Text="@SampleJson"
                RuntimeEvent="HandleRuntimeEvent" />

<section style="margin-top: 1.5rem; display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));">
    <section style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 1rem;">
        <h2 style="font-size: 1.1rem; margin-top: 0;">Reveal path</h2>
        <p style="margin-top: 0;">Enter an indexed path such as <code>$.owner.contact.email</code> or <code>$.items[1].score</code>.</p>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
            <input @bind="_revealPath"
                   style="flex: 1 1 16rem; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;"
                   aria-label="Reveal path" />
            <button @onclick="RevealPathAsync"
                    style="padding: 0.5rem 0.75rem; border: 1px solid #2563eb; background: #2563eb; color: white; border-radius: 4px; cursor: pointer;">
                Reveal path
            </button>
        </div>
        <div style="margin-top: 0.75rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <button @onclick='() => SetRevealPath("$.owner.contact.email")'>Reveal email</button>
            <button @onclick='() => SetRevealPath("$.items[1].score")'>Reveal second score</button>
        </div>
    </section>

    <section style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 1rem;">
        <h2 style="font-size: 1.1rem; margin-top: 0;">Transactions</h2>
        <p style="margin-top: 0;">Apply a deterministic <code>replaceValue</code> transaction against the sample document, then exercise minimal undo/redo support.</p>
        <p><strong>Current revision:</strong> @_currentRevision</p>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <button @onclick='() => ReplaceMilestoneAsync(4)'>Set milestone to 4</button>
            <button @onclick='() => ReplaceMilestoneAsync(5)'>Set milestone to 5</button>
            <button @onclick="UndoAsync">Undo</button>
            <button @onclick="RedoAsync">Redo</button>
        </div>
    </section>

    <section style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 1rem;">
        <h2 style="font-size: 1.1rem; margin-top: 0;">Latest runtime event</h2>
        <p><strong>Type:</strong> @_latestEvent.Type</p>
        <p><strong>Session:</strong> @_latestEvent.SessionId</p>
        <p><strong>Document:</strong> @_latestEvent.DocumentId</p>
        <p><strong>Transaction:</strong> @_latestEvent.TransactionId</p>
        <p><strong>Base revision:</strong> @_latestEvent.BaseRevision</p>
        <p><strong>New revision:</strong> @_latestEvent.NewRevision</p>
        <p><strong>Node count:</strong> @_latestEvent.NodeCount</p>
        <p><strong>Message:</strong> @_latestEvent.Message</p>
        <p><strong>Reason:</strong> @_latestEvent.Reason</p>
    </section>

    <section style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 1rem;">
        <h2 style="font-size: 1.1rem; margin-top: 0;">Parse diagnostics</h2>
        @if (_diagnostics.Count == 0)
        {
            <p>No diagnostics.</p>
        }
        else
        {
            <ul>
                @foreach (var diagnostic in _diagnostics)
                {
                    <li><strong>@diagnostic.Severity</strong>: @diagnostic.Message (@diagnostic.StartOffset-@diagnostic.EndOffset)</li>
                }
            </ul>
        }
    </section>

    <section style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 1rem;">
        <h2 style="font-size: 1.1rem; margin-top: 0;">Schema diagnostics</h2>
        @if (_schemaDiagnostics.Count == 0)
        {
            <p>No schema diagnostics.</p>
        }
        else
        {
            <ul>
                @foreach (var diagnostic in _schemaDiagnostics)
                {
                    <li><strong>@diagnostic.Severity</strong>: @diagnostic.Message (@diagnostic.Path)</li>
                }
            </ul>
        }
    </section>

    <section style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 1rem;">
        <h2 style="font-size: 1.1rem; margin-top: 0;">Schema metadata lookup</h2>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
            <input @bind="_schemaPath"
                   style="flex: 1 1 16rem; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;"
                   aria-label="Schema metadata path" />
            <button @onclick="LookupSchemaMetadataAsync">Lookup</button>
        </div>
        <pre style="margin-top: 0.75rem; white-space: pre-wrap;">@_schemaMetadataJson</pre>
    </section>

    <section style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 1rem;">
        <h2 style="font-size: 1.1rem; margin-top: 0;">Latest patch</h2>
        <pre style="margin: 0; white-space: pre-wrap;">@_latestPatchJson</pre>
    </section>
</section>

@code {
    private const string SampleSessionId = "sample-session";
    private const string MilestoneValueNodeId = "node-5";
    private static readonly JsonSerializerOptions PatchJsonOptions = new() { WriteIndented = true };
    private JsonVisualizer? _visualizer;
    private string _revealPath = "$.owner.contact.email";
    private RuntimeEventDto _latestEvent = new(RuntimeEventTypes.SessionCreated, SampleSessionId, "Waiting for runtime event.");
    private List<RuntimeDiagnosticDto> _diagnostics = [];
    private List<SchemaDiagnosticDto> _schemaDiagnostics = [];
    private string _latestPatchJson = "No patch emitted yet.";
    private string _schemaPath = "$.items[0].status";
    private string _schemaMetadataJson = "No schema metadata lookup yet.";
    private int _currentRevision;
    private int _nextTransactionNumber = 1;
    private bool _schemaAttached;
    private const string SampleSchemaId = "sample-schema-1";

    private const string SampleJson = """
{
  "project": "BlazorJsonVisualizer",
  "milestone": 3,
  "owner": {
    "name": "Carl Rabbit",
    "contact": {
      "email": "carl@example.invalid"
    }
  },
  "items": [
    {
      "name": "alpha",
      "score": "12"
    },
    {
      "name": "beta",
      "score": 34
    }
  ],
  "active": true,
  "notes": null
}
""";

    private const string SampleSchemaJson = """
{
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "title": "Project name"
    },
    "milestone": {
      "type": "number",
      "title": "Milestone number"
    },
    "items": {
      "type": "array",
      "title": "Work items",
      "items": {
        "type": "object",
        "required": ["name", "score", "status"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable item name"
          },
          "score": {
            "type": "number",
            "description": "Numeric score"
          },
          "status": {
            "type": "string",
            "enum": ["todo", "done"],
            "description": "Processing status",
            "default": "todo"
          }
        }
      }
    }
  },
  "required": ["project", "milestone", "items"]
}
""";

    private async Task RevealPathAsync()
    {
        if (_visualizer is null)
        {
            return;
        }

        await _visualizer.RevealPathAsync(_revealPath);
    }

    private async Task ReplaceMilestoneAsync(int milestone)
    {
        if (_visualizer is null)
        {
            return;
        }

        await _visualizer.ApplyTransactionAsync(new RuntimeTransactionDto(
            $"sample-replace-milestone-{_nextTransactionNumber++}",
            SampleSessionId,
            _currentRevision,
            RuntimeTransactionKinds.ReplaceValue,
            new RuntimeTransactionPayloadDto(
                NodeId: MilestoneValueNodeId,
                Value: JsonSerializer.SerializeToElement(milestone))));
    }

    private async Task UndoAsync()
    {
        if (_visualizer is null)
        {
            return;
        }

        await _visualizer.UndoAsync();
    }

    private async Task RedoAsync()
    {
        if (_visualizer is null)
        {
            return;
        }

        await _visualizer.RedoAsync();
    }

    private async Task LookupSchemaMetadataAsync()
    {
        if (_visualizer is null)
        {
            return;
        }

        var metadata = await _visualizer.GetSchemaMetadataForPathAsync(_schemaPath);
        _schemaMetadataJson = metadata is null
            ? "No schema metadata for this path."
            : JsonSerializer.Serialize(metadata, PatchJsonOptions);
    }

    private void SetRevealPath(string path)
    {
        _revealPath = path;
    }

    private async Task HandleRuntimeEvent(RuntimeEventDto runtimeEvent)
    {
        _latestEvent = runtimeEvent;

        if (runtimeEvent.Diagnostics is not null)
        {
            _diagnostics = runtimeEvent.Diagnostics.ToList();
        }

        if (runtimeEvent.SchemaDiagnostics is not null)
        {
            _schemaDiagnostics = runtimeEvent.SchemaDiagnostics.ToList();
        }

        if (runtimeEvent.NewRevision is not null)
        {
            _currentRevision = runtimeEvent.NewRevision.Value;
        }

        if (runtimeEvent.Patch is not null)
        {
            _latestPatchJson = JsonSerializer.Serialize(runtimeEvent.Patch, PatchJsonOptions);
        }

        if (runtimeEvent.Type == RuntimeEventTypes.DocumentLoaded && !_schemaAttached && _visualizer is not null)
        {
            using var document = JsonDocument.Parse(SampleSchemaJson);
            await _visualizer.AttachSchemaAsync(SampleSchemaId, document.RootElement.Clone());
            _schemaAttached = true;
        }

        await InvokeAsync(StateHasChanged);
    }
}
