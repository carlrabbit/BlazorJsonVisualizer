@using BlazorJsonVisualizer.Interop
@using BlazorJsonVisualizer.PreparedDocuments
@using System.Text.Json
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject IPreparedDocumentRuntimeBridge? PreparedDocumentRuntimeBridge

<div class="json-visualizer-shell">
    <div id="@_hostElementId"></div>
</div>

@code {
    private readonly string _hostElementId = $"bjv-{Guid.NewGuid():N}";
    private readonly string _generatedSessionId = Guid.NewGuid().ToString("N");
    private JsonVisualizerJsInterop? _interop;
    private DotNetObjectReference<JsonVisualizer>? _callbackReference;
    private bool _sessionCreated;

    [Parameter]
    public string? SessionId { get; set; }

    [Parameter]
    public string? DocumentId { get; set; }

    [Parameter]
    public string Text { get; set; } = "{}";

    [Parameter]
    public string? PreparedDocumentId { get; set; }

    [Parameter]
    public RuntimeOptionsDto? Options { get; set; }

    [Parameter]
    public EventCallback<RuntimeEventDto> RuntimeEvent { get; set; }

    private string EffectiveSessionId => string.IsNullOrWhiteSpace(SessionId) ? _generatedSessionId : SessionId;

    private string EffectiveDocumentId => string.IsNullOrWhiteSpace(DocumentId) ? $"{EffectiveSessionId}-document" : DocumentId;

    private string EffectivePreparedDocumentId => string.IsNullOrWhiteSpace(PreparedDocumentId) ? EffectiveDocumentId : PreparedDocumentId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _interop = new JsonVisualizerJsInterop(JSRuntime);
        _callbackReference = DotNetObjectReference.Create(this);

        await _interop.CreateSessionAsync(new CreateSessionCommand(_hostElementId, EffectiveSessionId, Options), _callbackReference);
        _sessionCreated = true;

        if (!string.IsNullOrWhiteSpace(PreparedDocumentId))
        {
            await _interop.OpenPreparedDocumentSessionAsync(new PreparedOpenRequestDto(EffectiveSessionId, EffectivePreparedDocumentId));
        }
        else if (!string.IsNullOrWhiteSpace(Text))
        {
            await _interop.LoadTextDocumentAsync(new LoadTextDocumentCommand(EffectiveSessionId, EffectiveDocumentId, Text));
        }
    }

    [JSInvokable]
    public async Task HandleRuntimeEvent(RuntimeEventDto runtimeEvent)
    {
        await RuntimeEvent.InvokeAsync(runtimeEvent);
    }

    [JSInvokable]
    public async Task<PreparedOpenResultDto> OpenPreparedDocumentSessionAsync(PreparedOpenRequestDto request)
        => PreparedDocumentRuntimeBridge is null
            ? CreateBridgeUnavailableOpenResult(request)
            : await PreparedDocumentRuntimeBridge.OpenAsync(request);

    [JSInvokable]
    public async Task<PreparedDocumentMetadataDto> GetPreparedDocumentMetadataAsync(string sessionId)
        => PreparedDocumentRuntimeBridge is null
            ? throw new InvalidOperationException("Prepared document runtime bridge is not registered.")
            : await PreparedDocumentRuntimeBridge.GetMetadataAsync(sessionId);

    [JSInvokable]
    public async Task<PreparedRowsResultDto> GetPreparedRowsAsync(PreparedRowsRequestDto request)
        => PreparedDocumentRuntimeBridge is null
            ? new PreparedRowsResultDto(request.SessionId, EffectivePreparedDocumentId, 0, request.FirstRow, request.RowCount, 0, [], [BridgeUnavailableDiagnostic()])
            : await PreparedDocumentRuntimeBridge.GetRowsAsync(request);

    [JSInvokable]
    public async Task<PreparedTextRangeDto> ReadPreparedTextRangeAsync(PreparedTextRangeRequestDto request)
        => PreparedDocumentRuntimeBridge is null
            ? new PreparedTextRangeDto(request.SessionId, EffectivePreparedDocumentId, 0, request.StartByteOffset, request.StartByteOffset, request.StartByteOffset, string.Empty, false, [BridgeUnavailableDiagnostic()])
            : await PreparedDocumentRuntimeBridge.ReadTextRangeAsync(request);

    [JSInvokable]
    public async Task<PreparedFoldStateResultDto> SetPreparedFoldStateAsync(PreparedFoldStateRequestDto request)
        => PreparedDocumentRuntimeBridge is null
            ? new PreparedFoldStateResultDto(false, 0, [BridgeUnavailableDiagnostic()])
            : await PreparedDocumentRuntimeBridge.SetFoldStateAsync(request);

    [JSInvokable]
    public async Task<PreparedSearchResultPageDto> SearchPreparedDocumentAsync(PreparedSearchRequestDto request)
        => PreparedDocumentRuntimeBridge is null
            ? new PreparedSearchResultPageDto(request.SessionId, EffectivePreparedDocumentId, 0, [], Diagnostics: [BridgeUnavailableDiagnostic()])
            : await PreparedDocumentRuntimeBridge.SearchAsync(request);

    [JSInvokable]
    public async Task<PreparedRevealResultDto> RevealPreparedLocationAsync(PreparedRevealRequestDto request)
        => PreparedDocumentRuntimeBridge is null
            ? new PreparedRevealResultDto(false, request.SessionId, EffectivePreparedDocumentId, "unsupported", Diagnostics: [BridgeUnavailableDiagnostic()])
            : await PreparedDocumentRuntimeBridge.RevealAsync(request);

    [JSInvokable]
    public async Task<PreparedCloseResultDto> ClosePreparedDocumentSessionAsync(string sessionId)
        => PreparedDocumentRuntimeBridge is null
            ? new PreparedCloseResultDto(false, [BridgeUnavailableDiagnostic()])
            : await PreparedDocumentRuntimeBridge.CloseAsync(sessionId);

    public async Task ToggleFoldAsync(string nodeId)
    {
        if (_interop is null || !_sessionCreated)
        {
            return;
        }

        await _interop.ToggleFoldAsync(new ToggleFoldCommand(EffectiveSessionId, nodeId));
    }

    public async Task RevealPathAsync(string path)
    {
        if (_interop is null || !_sessionCreated || string.IsNullOrWhiteSpace(path))
        {
            return;
        }

        await _interop.RevealPathAsync(new RevealPathCommand(EffectiveSessionId, path));
    }

    public async Task<PreparedSearchResultPageDto> SearchPreparedDocumentAsync(
        string query,
        int maxResults = 25,
        bool ignoreCase = true,
        string? continuationToken = null)
    {
        if (_interop is null || !_sessionCreated || string.IsNullOrWhiteSpace(PreparedDocumentId) || string.IsNullOrWhiteSpace(query))
        {
            return new PreparedSearchResultPageDto(EffectiveSessionId, EffectivePreparedDocumentId, 0, []);
        }

        return await _interop.SearchPreparedDocumentAsync(new PreparedSearchRequestDto(
            EffectiveSessionId,
            query,
            IgnoreCase: ignoreCase,
            MaxResults: maxResults,
            ContinuationToken: continuationToken));
    }

    public async Task<PreparedRevealResultDto> RevealPreparedJsonPointerAsync(string jsonPointer)
    {
        if (_interop is null || !_sessionCreated || string.IsNullOrWhiteSpace(PreparedDocumentId) || string.IsNullOrWhiteSpace(jsonPointer))
        {
            return new PreparedRevealResultDto(false, EffectiveSessionId, EffectivePreparedDocumentId, "invalidTarget");
        }

        return await _interop.RevealPreparedLocationAsync(new PreparedRevealRequestDto(EffectiveSessionId, new PreparedRevealTargetDto("jsonPointer", Path: jsonPointer)));
    }

    public async Task<PreparedRevealResultDto> RevealPreparedSearchResultAsync(PreparedSearchResultDto result)
    {
        ArgumentNullException.ThrowIfNull(result);
        if (_interop is null || !_sessionCreated || string.IsNullOrWhiteSpace(PreparedDocumentId))
        {
            return new PreparedRevealResultDto(false, EffectiveSessionId, EffectivePreparedDocumentId, "sessionNotFound");
        }

        return await _interop.RevealPreparedLocationAsync(new PreparedRevealRequestDto(
            EffectiveSessionId,
            new PreparedRevealTargetDto(
                "searchResult",
                StartByteOffset: result.StartByteOffset,
                EndByteOffset: result.EndByteOffset,
                ResultId: result.ResultId)));
    }

    public async Task ApplyTransactionAsync(RuntimeTransactionDto transaction)
    {
        if (_interop is null || !_sessionCreated)
        {
            return;
        }

        await _interop.ApplyTransactionAsync(new ApplyTransactionCommand(EffectiveSessionId, transaction));
    }

    public async Task AttachSchemaAsync(string schemaId, JsonElement schema)
    {
        if (_interop is null || !_sessionCreated || string.IsNullOrWhiteSpace(schemaId))
        {
            return;
        }

        await _interop.AttachSchemaAsync(new AttachSchemaCommand(EffectiveSessionId, schemaId, schema));
    }

    public async Task CreateProjectionAsync(string projectionId, string kind, string sourcePath)
    {
        if (_interop is null || !_sessionCreated || string.IsNullOrWhiteSpace(projectionId) || string.IsNullOrWhiteSpace(kind) || string.IsNullOrWhiteSpace(sourcePath))
        {
            return;
        }

        await _interop.CreateProjectionAsync(new CreateProjectionCommand(EffectiveSessionId, projectionId, kind, sourcePath));
    }

    public async Task DisposeProjectionAsync(string projectionId)
    {
        if (_interop is null || !_sessionCreated || string.IsNullOrWhiteSpace(projectionId))
        {
            return;
        }

        await _interop.DisposeProjectionAsync(new DisposeProjectionCommand(EffectiveSessionId, projectionId));
    }

    public async Task SelectProjectionItemAsync(string projectionId, ProjectionSelectionDto selection)
    {
        if (_interop is null || !_sessionCreated || string.IsNullOrWhiteSpace(projectionId))
        {
            return;
        }

        await _interop.SelectProjectionItemAsync(new SelectProjectionItemCommand(EffectiveSessionId, projectionId, selection));
    }

    public async Task DetachSchemaAsync(string schemaId)
    {
        if (_interop is null || !_sessionCreated || string.IsNullOrWhiteSpace(schemaId))
        {
            return;
        }

        await _interop.DetachSchemaAsync(new DetachSchemaCommand(EffectiveSessionId, schemaId));
    }

    public async Task<SchemaNodeMetadataDto?> GetSchemaMetadataForPathAsync(string path)
    {
        if (_interop is null || !_sessionCreated || string.IsNullOrWhiteSpace(path))
        {
            return null;
        }

        return await _interop.GetSchemaMetadataForPathAsync(new GetSchemaMetadataForPathCommand(EffectiveSessionId, path));
    }

    public async Task UndoAsync()
    {
        if (_interop is null || !_sessionCreated)
        {
            return;
        }

        await _interop.UndoAsync(new UndoCommand(EffectiveSessionId));
    }

    public async Task RedoAsync()
    {
        if (_interop is null || !_sessionCreated)
        {
            return;
        }

        await _interop.RedoAsync(new RedoCommand(EffectiveSessionId));
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_interop is not null && _sessionCreated)
            {
                if (!string.IsNullOrWhiteSpace(PreparedDocumentId))
                {
                    await _interop.ClosePreparedDocumentSessionAsync(EffectiveSessionId);
                }

                await _interop.DisposeSessionAsync(new DisposeSessionCommand(EffectiveSessionId));
            }
        }
        catch (JSDisconnectedException)
        {
        }
        finally
        {
            if (_interop is not null)
            {
                await _interop.DisposeAsync();
            }

            _callbackReference?.Dispose();
        }
    }

    private PreparedOpenResultDto CreateBridgeUnavailableOpenResult(PreparedOpenRequestDto request)
        => new(false, request.SessionId, request.DocumentId, Diagnostics: [BridgeUnavailableDiagnostic()]);

    private static RuntimeDiagnosticDto BridgeUnavailableDiagnostic()
        => new("prepared.bridgeUnavailable", "Prepared document runtime bridge is not registered.");
}
